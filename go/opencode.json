{
  "$schema": "https://opencode.ai/config.json",
  "model": "google-vertex-anthropic/claude-sonnet-4-6@default",
  "permission": {
    "external_directory": {
      "/tmp/*": "allow"
    },
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.env.example": "allow",
      "~/.config/*": "deny",
      "~/.config/opencode/*": "allow"
    },
    "bash": {
      "env": "deny",
      "env *": "deny",
      "printenv": "deny",
      "printenv *": "deny"
    },
    "skill": {
      "*": "allow"
    }
  }
}
